# Copy this file to .env.local for local development.

# Shared password used by the staff bookings panel.
# Replace this before deploying.
ADMIN_PASSWORD_HASH="change-this-password"

# Sanity public configuration.
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-06-23"

# Server-only Sanity editor token and webhook secret. Never expose these in client code.
SANITY_API_WRITE_TOKEN="your-write-token"
SANITY_GALLERY_WEBHOOK_SECRET="replace-with-a-long-random-secret"
